{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "check-deps",
			"type": "shell",
			"command": "python _check_deps.py && type _check_result.txt"
		},
		{
			"label": "check-deps2",
			"type": "shell",
			"command": "python _check_deps.py; Get-Content _check_result.txt"
		},
		{
			"label": "install-deps",
			"type": "shell",
			"command": "pip install PySide6 pynput"
		},
		{
			"label": "verify-imports",
			"type": "shell",
			"command": "python _check_deps.py; Get-Content _check_result.txt"
		},
		{
			"label": "smoke-test",
			"type": "shell",
			"command": "python _smoke_test.py"
		},
		{
			"label": "fix-pyside",
			"type": "shell",
			"command": "pip uninstall PySide6 PySide6-Essentials PySide6-Addons shiboken6 -y; pip install PySide6==6.7.3"
		},
		{
			"label": "smoke-test-2",
			"type": "shell",
			"command": "python _smoke_test.py"
		},
		{
			"label": "cleanup-tests",
			"type": "shell",
			"command": "Remove-Item _check_deps.py, _smoke_test.py, _check_result.txt -ErrorAction SilentlyContinue"
		}
	]
}